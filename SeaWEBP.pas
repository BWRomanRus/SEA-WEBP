const
  WEBP_DECODER_ABI_VERSION = $0209;
  WEBP_DEMUX_ABI_VERSION   = $0107;

type
  WEBP_CSP_MODE = (MODE_RGB=0, MODE_RGBA, MODE_BGR, MODE_BGRA, MODE_ARGB, MODE_RGBA_4444,
                   MODE_RGB_565, MODE_rgbI, MODE_bgrI, MODE_rgbI_4444, MODE_YUV, MODE_YUVA, MODE_LAST);
  TVP8StatusCode = (VP8_STATUS_OK=0, VP8_STATUS_OUT_OF_MEMORY, VP8_STATUS_INVALID_PARAM,
                    VP8_STATUS_BITSTREAM_ERROR, VP8_STATUS_UNSUPPORTED_FEATURE, VP8_STATUS_SUSPENDED,
                    VP8_STATUS_USER_ABORT, VP8_STATUS_NOT_ENOUGH_DATA);

  TWebPBitstreamFeatures = record
    width, height: Integer;
    has_alpha, has_animation, format: Integer;
    pad: array[0..4] of Cardinal;
  end;
  PWebPBitstreamFeatures = ^TWebPBitstreamFeatures;

  TWebPRGBABuffer = record rgba: PByte; stride: Integer; size: NativeUInt; end;
  TWebPYUVABuffer = record y,u,v,a: PByte; y_stride,u_stride,v_stride,a_stride: Integer; y_size,u_size,v_size,a_size: NativeUInt; end;
  TWebPDecBuffer = record
    colorspace: WEBP_CSP_MODE; width,height,is_external_memory: Integer;
    case Integer of
      0:(RGBA: TWebPRGBABuffer; pad1: array[0..3] of Cardinal; private_memory: PByte);
      1:(YUVA: TWebPYUVABuffer; pad2: array[0..3] of Cardinal; private_memory2: PByte);
  end; PWebPDecBuffer = ^TWebPDecBuffer;

  TWebPDecoderOptions = record
    bypass_filtering,no_fancy_upsampling,use_cropping,crop_left,crop_top,crop_width,crop_height: Integer;
    use_scaling,scaled_width,scaled_height: Integer; use_threads,dithering_strength,flip,alpha_dithering_strength: Integer;
    pad: array[0..4] of Cardinal;
  end;
  TWebPDecoderConfig = record input: TWebPBitstreamFeatures; output: TWebPDecBuffer; options: TWebPDecoderOptions; end;
  PWebPDecoderConfig = ^TWebPDecoderConfig;

  TWebPMuxAnimDispose = (WEBP_MUX_DISPOSE_NONE, WEBP_MUX_DISPOSE_BACKGROUND);
  TWebPMuxAnimBlend   = (WEBP_MUX_BLEND, WEBP_MUX_NO_BLEND);
  TWebPDemuxState = (WEBP_DEMUX_PARSE_ERROR=-1, WEBP_DEMUX_PARSING_HEADER=0, WEBP_DEMUX_PARSED_HEADER=1, WEBP_DEMUX_DONE=2);
  PWebPDemuxState = ^TWebPDemuxState;

  TWebPData = record bytes: PByte; size: NativeUInt; end;
  PWebPData = ^TWebPData;

  TWebPFormatFeature = (WEBP_FF_FORMAT_FLAGS, WEBP_FF_CANVAS_WIDTH, WEBP_FF_CANVAS_HEIGHT, WEBP_FF_LOOP_COUNT, WEBP_FF_BACKGROUND_COLOR, WEBP_FF_FRAME_COUNT);
  PWebPDemuxer = Pointer;

  TWebPIterator = record
    frame_num,num_frames,x_offset,y_offset,width,height,duration: Integer;
    dispose_method: TWebPMuxAnimDispose; complete: Integer; fragment: TWebPData; has_alpha: Integer; blend_method: TWebPMuxAnimBlend;
    pad: array[0..1] of Cardinal; private_: Pointer;
  end; PWebPIterator = ^TWebPIterator;

  // streaming anim
  TWebPAnimDecoderOptions = record color_mode,use_threads: Integer; padding: array[0..5] of Integer; end;
  PWebPAnimDecoderOptions = ^TWebPAnimDecoderOptions;
  TWebPAnimInfo = record canvas_width,canvas_height,loop_count,bgcolor,frame_count: Cardinal; pad: array[0..4] of Cardinal; end;
  PWebPAnimInfo = ^TWebPAnimInfo;
  PWebPAnimDecoder = Pointer;

// API pointers
type
  T_p_WebPFree = procedure(p: Pointer); cdecl;
  T_p_WebPGetFeaturesInternal = function(const data:PByte; data_size:NativeUInt; features:PWebPBitstreamFeatures; version:Integer):TVP8StatusCode; cdecl;
