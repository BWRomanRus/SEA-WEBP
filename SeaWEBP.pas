    FProc();
end;

class procedure TSyncCall.Execute(const AProc: TProc);
var
  C: TSyncCall;
begin
  C := TSyncCall.Create;
  try
    C.FProc := AProc;
    TThread.Synchronize(nil, C.DoSync);  // синхронно на главном потоке
  finally
    C.Free;
  end;
end;

// И заменяем InvokeMain на:



procedure InvokeMain(const P: TProc); inline;
begin
  if IsMainThread then
    P()
  else
    TSyncCall.Execute(P);
end;

// ======== Внутренние утилиты ========

procedure NeedLoaded;
begin
  if (GMod=nil) or (not GInited) then
    raise Exception.Create('libwebp(memory) не загружено');
end;

procedure BindProc(M:HMEMORYMODULE; const Name:AnsiString; var ProcVar); var P:Pointer;
begin
  P := MemoryGetProcAddress(M, PAnsiChar(Name));
  if P=nil then raise Exception.CreateFmt('libwebp: нет экспорта %s',[string(Name)]);
  Pointer(ProcVar) := P;
end;

function TryBindProc(M:HMEMORYMODULE; const Name:AnsiString; var ProcVar):Boolean; var P:Pointer;
begin
  P := MemoryGetProcAddress(M, PAnsiChar(Name));
  Result := (P<>nil); if Result then Pointer(ProcVar):=P else Pointer(ProcVar):=nil;
end;

procedure ZeroAllBindings;
begin
  _WebPFree := nil; _WebPGetFeaturesInternal := nil; _WebPInitDecoderConfigInternal := nil;
  _WebPInitDecBufferInternal := nil; _WebPFreeDecBuffer := nil; _WebPDecode := nil;
  _WebPDecodeRGBA := nil; _WebPDecodeBGRA := nil; _WebPDecodeBGRAInto := nil;

  _WebPGetDemuxVersion := nil; _WebPDemuxInternal := nil; _WebPDemuxDelete := nil;
  _WebPDemuxGetI := nil; _WebPDemuxGetFrame := nil; _WebPDemuxReleaseIterator := nil;

  _WebPAnimDecoderOptionsInitInternal := nil; _WebPAnimDecoderNewInternal := nil;
  _WebPAnimDecoderDelete := nil; _WebPAnimDecoderGetInfo := nil; _WebPAnimDecoderGetNext := nil;
  _WebPAnimDecoderHasMoreFrames := nil; _WebPAnimDecoderReset := nil;

  GDemuxReady := False; GAnimReady := False;
end;

procedure BindDecode(M:HMEMORYMODULE);
begin
  BindProc(M,'WebPFree',_WebPFree);
  BindProc(M,'WebPGetFeaturesInternal',_WebPGetFeaturesInternal);
  BindProc(M,'WebPInitDecoderConfigInternal',_WebPInitDecoderConfigInternal);
  BindProc(M,'WebPInitDecBufferInternal',_WebPInitDecBufferInternal);
  BindProc(M,'WebPFreeDecBuffer',_WebPFreeDecBuffer);
  BindProc(M,'WebPDecode',_WebPDecode);
  TryBindProc(M,'WebPDecodeRGBA',_WebPDecodeRGBA);
  TryBindProc(M,'WebPDecodeBGRA',_WebPDecodeBGRA);
  TryBindProc(M,'WebPDecodeBGRAInto',_WebPDecodeBGRAInto);
end;

procedure BindDemux(M:HMEMORYMODULE);
begin
  TryBindProc(M,'WebPGetDemuxVersion',_WebPGetDemuxVersion);
  TryBindProc(M,'WebPDemuxInternal',_WebPDemuxInternal);
  TryBindProc(M,'WebPDemuxDelete',_WebPDemuxDelete);
  TryBindProc(M,'WebPDemuxGetI',_WebPDemuxGetI);
  TryBindProc(M,'WebPDemuxGetFrame',_WebPDemuxGetFrame);
  TryBindProc(M,'WebPDemuxReleaseIterator',_WebPDemuxReleaseIterator);
  GDemuxReady := Assigned(_WebPDemuxInternal) and Assigned(_WebPDemuxDelete) and
                 Assigned(_WebPDemuxGetI) and Assigned(_WebPDemuxGetFrame) and Assigned(_WebPDemuxReleaseIterator);
end;

procedure BindAnim(M:HMEMORYMODULE);
begin
  TryBindProc(M,'WebPAnimDecoderOptionsInitInternal',_WebPAnimDecoderOptionsInitInternal);
  TryBindProc(M,'WebPAnimDecoderNewInternal',_WebPAnimDecoderNewInternal);
  TryBindProc(M,'WebPAnimDecoderDelete',_WebPAnimDecoderDelete);
  TryBindProc(M,'WebPAnimDecoderGetInfo',_WebPAnimDecoderGetInfo);
  TryBindProc(M,'WebPAnimDecoderGetNext',_WebPAnimDecoderGetNext);
  TryBindProc(M,'WebPAnimDecoderHasMoreFrames',_WebPAnimDecoderHasMoreFrames);
  TryBindProc(M,'WebPAnimDecoderReset',_WebPAnimDecoderReset);
  GAnimReady := Assigned(_WebPAnimDecoderNewInternal) and Assigned(_WebPAnimDecoderOptionsInitInternal) and
                Assigned(_WebPAnimDecoderDelete) and Assigned(_WebPAnimDecoderGetInfo) and
                Assigned(_WebPAnimDecoderGetNext) and Assigned(_WebPAnimDecoderHasMoreFrames) and
                Assigned(_WebPAnimDecoderReset);
end;

procedure BindAll(M:HMEMORYMODULE);
begin BindDecode(M); BindDemux(M); BindAnim(M); GInited := True; end;

function ExtractResourceToBytesW(Inst:HINST; const ResName,ResType:PWideChar; out Data:TBytes):Boolean;
var hRes:HRSRC; hData:HGLOBAL; p:Pointer; sz:DWORD;
begin
  Result := False; SetLength(Data,0);
  hRes := FindResourceW(Inst,ResName,ResType); if hRes=0 then Exit;
  sz := SizeofResource(Inst,hRes); if sz=0 then Exit;
  hData := LoadResource(Inst,hRes); if hData=0 then Exit;
  p := LockResource(hData); if p=nil then Exit;
  SetLength(Data,sz); Move(p^,Data[0],sz); Result := True;
end;

type
  TFileMap = record
    hFile, hMap: THandle; View: Pointer; Size: UInt64;
    procedure Open(const FileName: string);
    procedure Close;
  end;

procedure TFileMap.Open(const FileName:string);
var hi,lo:DWORD;
begin
  FillChar(Self,SizeOf(Self),0);
  hFile := CreateFile(PChar(FileName),GENERIC_READ,FILE_SHARE_READ,nil,OPEN_EXISTING,FILE_ATTRIBUTE_NORMAL,0);
  if hFile=INVALID_HANDLE_VALUE then raise Exception.CreateFmt('WebP: open fail %s',[FileName]);
  lo := GetFileSize(hFile,@hi); Size := UInt64(hi) shl 32 or UInt64(lo);
  hMap := CreateFileMapping(hFile,nil,PAGE_READONLY,hi,lo,nil);
  if hMap=0 then begin CloseHandle(hFile); raise Exception.Create('WebP: CreateFileMapping'); end;
  View := MapViewOfFile(hMap,FILE_MAP_READ,0,0,0);
  if View=nil then begin CloseHandle(hMap); CloseHandle(hFile); raise Exception.Create('WebP: MapViewOfFile'); end;
end;

procedure TFileMap.Close;
begin
  if View<>nil then UnmapViewOfFile(View);
  if hMap<>0 then CloseHandle(hMap);
  if hFile<>0 then CloseHandle(hFile);
  FillChar(Self,SizeOf(Self),0);
end;

// ======== Загрузка/выгрузка DLL с блокировкой и защитой от активных плееров ========

function webp_load_from_memory(const MS:TMemoryStream):Boolean;
begin
  EnterCriticalSection(GLoadCS);
  try
    if InterlockedCompareExchange(GActivePlayers, 0, 0) <> 0 then
      raise Exception.Create('webp: библиотека занята активными плеерами; сначала закройте их');
    webp_unload;
    if (MS=nil) or (MS.Size=0) then raise Exception.Create('webp_load_from_memory: пустой поток');
    GMod := MemoryLoadLibrary(MS.Memory, MS.Size); Result := (GMod<>nil);
    if Result then BindAll(GMod);
  finally
    LeaveCriticalSection(GLoadCS);
  end;
end;

function webp_load_from_buffer(Buffer:Pointer; BufferSize:NativeUInt):Boolean;
begin
  EnterCriticalSection(GLoadCS);
  try
    if InterlockedCompareExchange(GActivePlayers, 0, 0) <> 0 then
      raise Exception.Create('webp: библиотека занята активными плеерами; сначала закройте их');
    webp_unload;
    if (Buffer=nil) or (BufferSize=0) then raise Exception.Create('webp_load_from_buffer: пустой буфер');
    GMod := MemoryLoadLibrary(Buffer, BufferSize); Result := (GMod<>nil);
    if Result then BindAll(GMod);
  finally
    LeaveCriticalSection(GLoadCS);
  end;
end;

function webp_load_from_resourceW(const ResName,ResType:PWideChar):Boolean;
var bytes:TBytes;
begin
  EnterCriticalSection(GLoadCS);
  try
    if InterlockedCompareExchange(GActivePlayers, 0, 0) <> 0 then
      raise Exception.Create('webp: библиотека занята активными плеерами; сначала закройте их');
    if not ExtractResourceToBytesW(HInstance,ResName,ResType,bytes) then
      raise Exception.CreateFmt('Ресурс не найден: %s/%s',[string(ResName),string(ResType)]);
    Result := webp_load_from_buffer(@bytes[0], Length(bytes));
  finally
    LeaveCriticalSection(GLoadCS);
  end;
end;

procedure webp_unload;
begin
  EnterCriticalSection(GLoadCS);
  try
    if GMod<>nil then begin MemoryFreeLibrary(GMod); GMod:=nil; end;
    GInited := False; ZeroAllBindings;
  finally
    LeaveCriticalSection(GLoadCS);
  end;
end;

function webp_is_loaded:Boolean; begin Result := (GMod<>nil) and GInited; end;

// ======== статичная картинка ========

procedure PremultiplyBGRA_Bitmap(B:TBitmap);
var y,x:Integer; p:PByte; a:Integer;
begin
  if (B=nil) or (B.PixelFormat<>pf32bit) then Exit;
  for y:=0 to B.Height-1 do begin
    p:=B.ScanLine[y];
    for x:=0 to B.Width-1 do begin
      a := p[3];
      if a<255 then begin p[0]:=(p[0]*a+127) div 255; p[1]:=(p[1]*a+127) div 255; p[2]:=(p[2]*a+127) div 255; end;
      Inc(p,4);
    end;
  end;
end;

procedure LoadWebPPtrToImage(DataPtr:PByte; DataSize:NativeUInt; Img:TImage);
var Feat:TWebPBitstreamFeatures; St:TVP8StatusCode; HasAlpha:Boolean;
    B:TBitmap; RowSize,y:Integer; BGRA,Src,Dst:PByte; W,H:Integer;
begin
  NeedLoaded;
  St := _WebPGetFeaturesInternal(DataPtr,DataSize,@Feat,WEBP_DECODER_ABI_VERSION);
  if St<>VP8_STATUS_OK then raise Exception.CreateFmt('WebPGetFeatures=%d',[Ord(St)]);
  HasAlpha := Feat.has_alpha<>0;

  InvokeMain(procedure
  begin
    B := Img.Picture.Bitmap; // работаем напрямую с Bitmap
    B.HandleType := bmDIB; B.PixelFormat := pf32bit;
    B.SetSize(Feat.width, Feat.height);
    {$IF DECLARED(afPremultiplied)} if HasAlpha then B.AlphaFormat:=afPremultiplied else B.AlphaFormat:=afIgnored; {$IFEND}
  end);

  RowSize := Feat.width*4;

  if Assigned(_WebPDecodeBGRAInto) then
  begin
    // кладём прямо в bottom-up DIB с отрицательным stride
    InvokeMain(procedure
    var dest:PByte;
    begin
      dest := PByte(Img.Picture.Bitmap.ScanLine[Img.Picture.Bitmap.Height-1]);
      BGRA := _WebPDecodeBGRAInto(DataPtr,DataSize,dest, NativeUInt(Img.Picture.Bitmap.Height*RowSize), -RowSize);
      if BGRA=nil then raise Exception.Create('WebPDecodeBGRAInto=nil');
    end);
    if HasAlpha then InvokeMain(procedure begin PremultiplyBGRA_Bitmap(Img.Picture.Bitmap); end);
  end
  else
  begin
    BGRA := _WebPDecodeBGRA(DataPtr,DataSize,W,H);
    if BGRA=nil then raise Exception.Create('WebPDecodeBGRA=nil');
    InvokeMain(procedure
    begin
      for var y:=0 to H-1 do
      begin
        Src := BGRA + NativeUInt(y)*NativeUInt(RowSize);
        Dst := Img.Picture.Bitmap.ScanLine[H-1-y];
        Move(Src^,Dst^,RowSize);
      end;
      if HasAlpha then PremultiplyBGRA_Bitmap(Img.Picture.Bitmap);
    end);
    _WebPFree(BGRA);
  end;
end;

procedure LoadWebPToImage(const FileName:string; Img:TImage);
var Map:TFileMap;
begin
  NeedLoaded; if not TFile.Exists(FileName) then raise Exception.CreateFmt('Файл не найден: %s',[FileName]);
  Map.Open(FileName);
  try
    if Map.Size>High(NativeUInt) then raise Exception.Create('WebP: слишком большой для 32-bit');
    LoadWebPPtrToImage(PByte(Map.View), NativeUInt(Map.Size), Img);
  finally
    Map.Close;
  end;
end;

procedure LoadWebPToImage(const mswebp:TMemoryStream; Img:TImage); overload;
begin
  NeedLoaded;
  if (mswebp=nil) or (mswebp.Size=0) then raise Exception.Create('LoadWebPToImage: пустой поток');
  LoadWebPPtrToImage(PByte(mswebp.Memory), mswebp.Size, Img);
end;

// ======== анимация ========

function ARGBToColorRef(c:Cardinal):COLORREF; inline;
begin Result := RGB((c shr 16) and $FF, (c shr 8) and $FF, c and $FF); end;

type
  TAnimState=(asNone,asPlaying,asPaused,asStopped);
  TWebPAnimator = class;

  TSentinel = class(TComponent)
  private
    FAnim: TWebPAnimator;
  protected
    procedure Notification(AComponent: TComponent; Operation: TOperation); override;
  public
    constructor Create(AOwner: TComponent; Anim: TWebPAnimator); reintroduce;
  end;

  TWebPAnimator = class
  private
    // streaming
    FUseAnimDec:Boolean;
    FAnimDec:PWebPAnimDecoder;
    FInfo:TWebPAnimInfo;
    FData:TWebPData;
    FMap:TFileMap;    // если из файла
    FBytes:TBytes;    // если из памяти

    // общие
    FImg:TImage;
    FTimer:TTimer;
    FState:TAnimState;
    FLoopFlag:Boolean;
    FLoopsFromFile:Integer;
    FPlayedLoops:Integer;

    // вывод: единый top-down DIB (подвязан к TImage.Bitmap)
    FCanvasBits:PByte;
    FCanvasStride, FCanvasW, FCanvasH: Integer;

    // тайминг
    FNextDueMS:UInt64;
    FPrevTS:Integer;

    // fallback-хранилище (если нет AnimDecoder)
    FFrames: array of TBitmap;
    FDelays: array of Cardinal;

    // sentinel
    FSentinel: TSentinel;

    procedure StartHiResTimer; inline;
    procedure StopHiResTimer; inline;

    procedure AllocCanvasDIB(W,H:Integer);
    procedure PresentFromBufTopDown(src:PByte); inline;
    procedure PresentBitmapBottomUp(const B:TBitmap); inline;

    procedure OnTick(Sender:TObject);
    function  ComputeNextInterval:Cardinal; inline;
    class function ClampDelay(const D:Integer):Cardinal; static; inline;

    procedure InitAnimDecoder;
    function  StepDecoderAndSchedule:Boolean;

    procedure BuildFramesByDemux;
    procedure ClearFrames;

    procedure DetachImage; // если Img уничтожен
  public
    constructor CreateFromFile(const FileName:string; Img:TImage; Loop:Boolean);
    constructor CreateFromBytes(const Bytes:TBytes; Img:TImage; Loop:Boolean);
    destructor Destroy; override;

    procedure Start; procedure Pause; procedure Resume; procedure Stop; procedure Restart;
    procedure SetLoop(LoopForever:Boolean);

    function IsPlaying:Boolean; inline;
    function IsPaused:Boolean; inline;
    function IsStopped:Boolean; inline;
  end;

{ TSentinel }

constructor TSentinel.Create(AOwner: TComponent; Anim: TWebPAnimator);
begin
  inherited Create(AOwner);
  FAnim := Anim;
end;

procedure TSentinel.Notification(AComponent: TComponent; Operation: TOperation);
begin
  inherited;
  if (Operation = opRemove) and Assigned(FAnim) and (AComponent = FAnim.FImg) then
    FAnim.DetachImage; // безопасно отключаем вывод
end;

{ TWebPAnimator }

class function TWebPAnimator.ClampDelay(const D:Integer):Cardinal;
var v:Integer; begin v:=D; if v<=0 then v:=100; if v<10 then v:=10; Result:=Cardinal(v); end;

procedure TWebPAnimator.StartHiResTimer; begin timeBeginPeriod(1); end;
procedure TWebPAnimator.StopHiResTimer;  begin timeEndPeriod(1);    end;

procedure TWebPAnimator.AllocCanvasDIB(W,H:Integer);
var BI: BITMAPINFO; bits: Pointer; hbm: HBITMAP;
begin
  if (FImg=nil) then Exit;
  FillChar(BI, SizeOf(BI), 0);
  BI.bmiHeader.biSize := SizeOf(BI.bmiHeader);
  BI.bmiHeader.biWidth := W;
  BI.bmiHeader.biHeight := -H; // top-down!
  BI.bmiHeader.biPlanes := 1;
  BI.bmiHeader.biBitCount := 32;
  BI.bmiHeader.biCompression := BI_RGB;

  hbm := CreateDIBSection(0, BI, DIB_RGB_COLORS, bits, 0, 0);
  if hbm=0 then raise Exception.Create('CreateDIBSection failed');

  FImg.Picture.Bitmap.HandleType := bmDIB;
  FImg.Picture.Bitmap.PixelFormat := pf32bit;
  FImg.Picture.Bitmap.Handle := hbm;
  FCanvasBits := bits;
  FCanvasW := W; FCanvasH := H; FCanvasStride := W*4;
  {$IF DECLARED(afPremultiplied)} FImg.Picture.Bitmap.AlphaFormat := afPremultiplied; {$IFEND}
end;

procedure TWebPAnimator.PresentFromBufTopDown(src:PByte);
begin
  if (FImg=nil) or (FCanvasBits=nil) then Exit;
  Move(src^, FCanvasBits^, NativeUInt(FCanvasStride)*NativeUInt(FCanvasH));
  FImg.Invalidate;
end;

procedure TWebPAnimator.PresentBitmapBottomUp(const B:TBitmap);
var y:Integer; src,dst:PByte;
begin
  if (FImg=nil) or (FCanvasBits=nil) then Exit;
  for y:=0 to B.Height-1 do
  begin
    src := PByte(B.ScanLine[B.Height-1-y]);
    dst := FCanvasBits + NativeUInt(y)*NativeUInt(FCanvasStride);
    Move(src^, dst^, FCanvasStride);
  end;
  FImg.Invalidate;
end;

procedure TWebPAnimator.InitAnimDecoder;
var opt:TWebPAnimDecoderOptions; buf:PByte; ts:Integer;
begin
  FillChar(opt,SizeOf(opt),0);
  if Assigned(_WebPAnimDecoderOptionsInitInternal) then
    _WebPAnimDecoderOptionsInitInternal(@opt, WEBP_DEMUX_ABI_VERSION);
  opt.color_mode := Ord(MODE_bgrI); // premul BGRA
  opt.use_threads := 1;

  FAnimDec := _WebPAnimDecoderNewInternal(@FData, @opt, WEBP_DEMUX_ABI_VERSION);
  if FAnimDec=nil then raise Exception.Create('WebPAnimDecoderNewInternal failed');
  if _WebPAnimDecoderGetInfo(FAnimDec, @FInfo)=0 then raise Exception.Create('WebPAnimDecoderGetInfo failed');

  FLoopsFromFile := Integer(FInfo.loop_count);

  // не трогаем GUI здесь
  if _WebPAnimDecoderGetNext(FAnimDec, buf, ts)<>0 then
  begin
    // просто запомним тайминг; кадр покажем позже в Start
    FPrevTS := ts;
    FNextDueMS := GetTickCount64 + ClampDelay(ts);
    _WebPAnimDecoderReset(FAnimDec);
    FPrevTS := 0;
  end
  else
  begin
    FPrevTS := 0;
    FNextDueMS := GetTickCount64 + 30;
  end;

  FUseAnimDec := True;
end;

function TWebPAnimator.StepDecoderAndSchedule:Boolean;
var buf:PByte; ts:Integer; nowMS:UInt64; delay:Cardinal;
begin
  Result := True;
  if _WebPAnimDecoderGetNext(FAnimDec, buf, ts)=0 then
  begin
    if FLoopFlag or (FLoopsFromFile=0) then
    begin
      _WebPAnimDecoderReset(FAnimDec);
      FPrevTS := 0;
      if _WebPAnimDecoderGetNext(FAnimDec, buf, ts)=0 then begin Result := False; Exit; end;
    end
    else begin Result := False; Exit; end;
  end;

  PresentFromBufTopDown(buf);

  delay := ClampDelay(ts - FPrevTS);
  FPrevTS := ts;
  nowMS := GetTickCount64;
  FNextDueMS := nowMS + delay;
end;

procedure TWebPAnimator.BuildFramesByDemux;
var dmux:PWebPDemuxer; Iter:TWebPIterator; CanvasW,CanvasH:Integer; LoopCount,BG:Cardinal;
    CanvasBmp,FragBmp,FrameBmp:TBitmap; i,y:Integer; DstRow,SrcRow:PByte; BF:TBlendFunction;
begin
  if not GDemuxReady then raise Exception.Create('Demux API отсутствует');

  dmux := _WebPDemuxInternal(@FData,0,nil,WEBP_DEMUX_ABI_VERSION);
  if dmux=nil then raise Exception.Create('Demux create fail');

  try
    CanvasW := _WebPDemuxGetI(dmux, WEBP_FF_CANVAS_WIDTH);
    CanvasH := _WebPDemuxGetI(dmux, WEBP_FF_CANVAS_HEIGHT);
    LoopCount := _WebPDemuxGetI(dmux, WEBP_FF_LOOP_COUNT);
    BG := _WebPDemuxGetI(dmux, WEBP_FF_BACKGROUND_COLOR);
    FLoopsFromFile := Integer(LoopCount);

    FillChar(Iter,SizeOf(Iter),0);
    if _WebPDemuxGetFrame(dmux,1,Iter)=0 then raise Exception.Create('Demux: нет первого кадра');
    try
      SetLength(FFrames, Iter.num_frames);
      SetLength(FDelays, Iter.num_frames);
    finally
      _WebPDemuxReleaseIterator(@Iter);
      FillChar(Iter,SizeOf(Iter),0);
    end;

    CanvasBmp := TBitmap.Create;
    try
      CanvasBmp.PixelFormat := pf32bit; CanvasBmp.SetSize(CanvasW, CanvasH);
      {$IF DECLARED(afPremultiplied)} CanvasBmp.AlphaFormat := afPremultiplied; {$IFEND}
      CanvasBmp.Canvas.Brush.Color := ARGBToColorRef(BG);
      CanvasBmp.Canvas.FillRect(Rect(0,0,CanvasW,CanvasH));
      BF.BlendOp := AC_SRC_OVER; BF.BlendFlags := 0; BF.SourceConstantAlpha := $FF; BF.AlphaFormat := AC_SRC_ALPHA;

      for i:=1 to Length(FFrames) do
      begin
        if _WebPDemuxGetFrame(dmux,i,Iter)=0 then raise Exception.CreateFmt('Demux: frame %d нет',[i]);

        var cfg:TWebPDecoderConfig;
        if _WebPInitDecoderConfigInternal(@cfg, WEBP_DECODER_ABI_VERSION)=0 then raise Exception.Create('InitDecoderConfig fail');
        cfg.output.colorspace := MODE_bgrI;
        if _WebPDecode(Iter.fragment.bytes, Iter.fragment.size, @cfg)<>VP8_STATUS_OK then
          raise Exception.Create('Decode(frame) fail');

        FragBmp := TBitmap.Create;
        try
          FragBmp.PixelFormat := pf32bit; FragBmp.SetSize(Iter.width, Iter.height);
          {$IF DECLARED(afPremultiplied)} FragBmp.AlphaFormat := afPremultiplied; {$IFEND}
          for y:=0 to Iter.height-1 do begin
            SrcRow := cfg.output.RGBA.rgba + NativeUInt(y)*NativeUInt(cfg.output.RGBA.stride);
            DstRow := PByte(FragBmp.ScanLine[y]);
            Move(SrcRow^, DstRow^, Iter.width*4);
          end;
        finally
          _WebPFreeDecBuffer(@cfg.output);
        end;

        if Iter.blend_method=WEBP_MUX_BLEND then
          AlphaBlend(CanvasBmp.Canvas.Handle, Iter.x_offset,Iter.y_offset, FragBmp.Width,FragBmp.Height,
                     FragBmp.Canvas.Handle, 0,0, FragBmp.Width,FragBmp.Height, BF)
        else
          for y:=0 to FragBmp.Height-1 do begin
            SrcRow := PByte(FragBmp.ScanLine[y]);
            DstRow := PByte(CanvasBmp.ScanLine[Iter.y_offset+y]); Inc(DstRow, Iter.x_offset*4);
            Move(SrcRow^, DstRow^, FragBmp.Width*4);
          end;

        FrameBmp := TBitmap.Create;
        try
          FrameBmp.PixelFormat := pf32bit; FrameBmp.SetSize(CanvasBmp.Width, CanvasBmp.Height);
          {$IF DECLARED(afPremultiplied)} FrameBmp.AlphaFormat := afPremultiplied; {$IFEND}
          for y:=0 to CanvasBmp.Height-1 do
            Move(PByte(CanvasBmp.ScanLine[y])^, PByte(FrameBmp.ScanLine[y])^, CanvasBmp.Width*4);
          FFrames[i-1] := FrameBmp;
        except
          FrameBmp.Free; raise;
        end;

        FDelays[i-1] := ClampDelay(Iter.duration);

        if Iter.dispose_method=WEBP_MUX_DISPOSE_BACKGROUND then
        begin
          CanvasBmp.Canvas.Brush.Color := ARGBToColorRef(BG);
          CanvasBmp.Canvas.FillRect(Rect(Iter.x_offset,Iter.y_offset,Iter.x_offset+Iter.width,Iter.y_offset+Iter.height));
        end;

        _WebPDemuxReleaseIterator(@Iter);
        FragBmp.Free;
      end;
    finally
      CanvasBmp.Free;
    end;
  finally
    _WebPDemuxDelete(dmux);
  end;

  FNextDueMS := GetTickCount64 + 30;
end;

procedure TWebPAnimator.ClearFrames;
var i:Integer; begin
  for i:=0 to High(FFrames) do if Assigned(FFrames[i]) then FFrames[i].Free;
  SetLength(FFrames,0); SetLength(FDelays,0);
end;

procedure TWebPAnimator.DetachImage;
begin
  // вызывается из Sentinel при уничтожении TImage
  if Assigned(FTimer) then FTimer.Enabled := False;
  FImg := nil;
  FCanvasBits := nil; FCanvasW:=0; FCanvasH:=0; FCanvasStride:=0;
end;

constructor TWebPAnimator.CreateFromFile(const FileName:string; Img:TImage; Loop:Boolean);
var ownerComp: TComponent;
begin
  inherited Create; NeedLoaded;
  if not TFile.Exists(FileName) then raise Exception.CreateFmt('Файл не найден: %s',[FileName]);

  FImg:=Img; FLoopFlag:=Loop; FState:=asStopped; FPlayedLoops:=0; FUseAnimDec:=False;
  InterlockedIncrement(GActivePlayers);

  if Assigned(FImg) and Assigned(FImg.Owner) then ownerComp := FImg.Owner else ownerComp := Application;

  InvokeMain(procedure
  begin
    FTimer:=TTimer.Create(ownerComp); FTimer.Enabled:=False; FTimer.Interval:=5; FTimer.OnTimer:=OnTick;
    if Assigned(FImg) then begin
      FSentinel := TSentinel.Create(ownerComp, Self);
      FImg.FreeNotification(FSentinel);
    end;
  end);

  FMap.Open(FileName);
  if FMap.Size>High(NativeUInt) then raise Exception.Create('WebP: слишком большой для 32-bit');

  FData.bytes := PByte(FMap.View); FData.size := NativeUInt(FMap.Size);

  if GAnimReady then InitAnimDecoder else BuildFramesByDemux;
end;

constructor TWebPAnimator.CreateFromBytes(const Bytes:TBytes; Img:TImage; Loop:Boolean);
var ownerComp: TComponent;
begin
  inherited Create; NeedLoaded;
  FImg:=Img; FLoopFlag:=Loop; FState:=asStopped; FPlayedLoops:=0; FUseAnimDec:=False;
  InterlockedIncrement(GActivePlayers);

  if Assigned(FImg) and Assigned(FImg.Owner) then ownerComp := FImg.Owner else ownerComp := Application;

  InvokeMain(procedure
  begin
    FTimer:=TTimer.Create(ownerComp); FTimer.Enabled:=False; FTimer.Interval:=5; FTimer.OnTimer:=OnTick;
    if Assigned(FImg) then begin
      FSentinel := TSentinel.Create(ownerComp, Self);
      FImg.FreeNotification(FSentinel);
    end;
  end);

  FBytes := Bytes; if Length(FBytes)=0 then raise Exception.Create('WebP: пустые данные');
  FData.bytes := @FBytes[0]; FData.size := Length(FBytes);

  if GAnimReady then InitAnimDecoder else BuildFramesByDemux;
end;

destructor TWebPAnimator.Destroy;
begin
  InvokeMain(procedure
  begin
    if Assigned(FTimer) then begin FTimer.Enabled:=False; FTimer.OnTimer:=nil; FreeAndNil(FTimer); end;
    if Assigned(FImg) and Assigned(FSentinel) then FImg.RemoveFreeNotification(FSentinel);
    FreeAndNil(FSentinel);
  end);

  StopHiResTimer;
  if FUseAnimDec and Assigned(FAnimDec) then _WebPAnimDecoderDelete(FAnimDec);
  ClearFrames;
  FMap.Close;
  InterlockedDecrement(GActivePlayers);
  inherited;
end;

procedure TWebPAnimator.OnTick(Sender:TObject);
const MAX_STEPS = 5;
var steps:Integer; nowMS:UInt64;
begin
  if FState<>asPlaying then Exit;

  steps := 0;
  nowMS := GetTickCount64;

  while (nowMS >= FNextDueMS) and (steps < MAX_STEPS) do
  begin
    if FUseAnimDec then
    begin
      if not StepDecoderAndSchedule then
      begin
        FTimer.Enabled := False; FState := asStopped; StopHiResTimer; Exit;
      end;
    end
    else
    begin
      if Length(FFrames)=0 then begin FTimer.Enabled:=False; FState:=asStopped; Exit; end;
      var idx := (FPlayedLoops shl 30); // not used, просто чтобы компилятор не ругался
      if Assigned(FImg) then idx := FImg.Tag;
      Inc(idx); if idx>=Length(FFrames) then
      begin
        if FLoopFlag or (FLoopsFromFile=0) then
        begin
          idx := 0;
          if FLoopsFromFile>0 then begin Inc(FPlayedLoops); if FPlayedLoops>=FLoopsFromFile then begin FTimer.Enabled:=False; FState:=asStopped; Exit; end; end;
        end
        else begin FTimer.Enabled:=False; FState:=asStopped; Exit; end;
      end;
      PresentBitmapBottomUp(FFrames[idx]);
      if Assigned(FImg) then FImg.Tag := idx;
      FNextDueMS := GetTickCount64 + FDelays[idx];
    end;

    Inc(steps);
    nowMS := GetTickCount64;
  end;

  FTimer.Interval := ComputeNextInterval;
end;

function TWebPAnimator.ComputeNextInterval:Cardinal;
var nowMS:UInt64; remain:Int64;
begin
  nowMS := GetTickCount64;
  remain := Int64(FNextDueMS) - Int64(nowMS);
  if remain<=1 then Result:=1 else if remain>60000 then Result:=60000 else Result:=Cardinal(remain);
end;

procedure TWebPAnimator.Start;
begin
  if FState=asPlaying then Exit;

  InvokeMain(procedure
  var buf:PByte; ts:Integer;
  begin
    StartHiResTimer;
    FState := asPlaying;

    if FUseAnimDec then
    begin
      if (FCanvasBits=nil) and (FInfo.canvas_width>0) then
        AllocCanvasDIB(FInfo.canvas_width, FInfo.canvas_height);

      _WebPAnimDecoderReset(FAnimDec);
      FPrevTS := 0;
      if _WebPAnimDecoderGetNext(FAnimDec, buf, ts)<>0 then
      begin
        PresentFromBufTopDown(buf);
        FNextDueMS := GetTickCount64 + ClampDelay(ts);
        FPrevTS := ts;
      end
      else
      begin
        FState := asStopped;
      end;
    end
    else if (Length(FFrames)>0) then
    begin
      if (FCanvasBits=nil) then
        AllocCanvasDIB(FFrames[0].Width, FFrames[0].Height);
      FImg.Tag := 0;
      PresentBitmapBottomUp(FFrames[0]);
      FNextDueMS := GetTickCount64 + FDelays[0];
    end
    else
      FState := asStopped;

    FTimer.Interval := ComputeNextInterval;
    FTimer.Enabled := (FState=asPlaying);
  end);
end;

procedure TWebPAnimator.Pause; begin if FState<>asPlaying then Exit; FTimer.Enabled:=False; FState:=asPaused; StopHiResTimer; end;
procedure TWebPAnimator.Resume; begin if FState<>asPaused then Exit; StartHiResTimer; FState:=asPlaying; FTimer.Enabled:=True; FTimer.Interval:=ComputeNextInterval; end;

procedure TWebPAnimator.Stop;
begin
  InvokeMain(procedure
  begin
    if FTimer<>nil then FTimer.Enabled := False;
    FState := asStopped; StopHiResTimer;

    if FUseAnimDec and Assigned(FAnimDec) then
    begin
      _WebPAnimDecoderReset(FAnimDec);
      FPrevTS := 0;
      var buf:PByte; var ts:Integer;
      if _WebPAnimDecoderGetNext(FAnimDec, buf, ts)<>0 then
      begin
        PresentFromBufTopDown(buf);
        FNextDueMS := GetTickCount64 + ClampDelay(ts);
        FPrevTS := ts;
      end;
    end
    else if (Length(FFrames)>0) then
      PresentBitmapBottomUp(FFrames[0]);

    FPlayedLoops := 0;
  end);
end;

procedure TWebPAnimator.Restart; begin Stop; Start; end;
procedure TWebPAnimator.SetLoop(LoopForever:Boolean); begin FLoopFlag:=LoopForever; end;

function TWebPAnimator.IsPlaying:Boolean; begin Result:=FState=asPlaying; end;
function TWebPAnimator.IsPaused:Boolean;  begin Result:=FState=asPaused;  end;
function TWebPAnimator.IsStopped:Boolean; begin Result:=FState=asStopped; end;

// ======== публичные вызовы ========

function WebPOpenStream(const mswebp:TMemoryStream; Img:TImage; Loop:Boolean):HWEBP;
var Bytes:TBytes;
begin
  NeedLoaded;
  if (mswebp=nil) or (mswebp.Size=0) then raise Exception.Create('WebPOpenStream: пустой поток');
  SetLength(Bytes, mswebp.Size); Move(mswebp.Memory^, Bytes[0], mswebp.Size);
  Result := HWEBP(TWebPAnimator.CreateFromBytes(Bytes, Img, Loop));
end;

function WebPOpenFile(const FileName:string; Img:TImage; Loop:Boolean):HWEBP;
begin
  NeedLoaded; if not TFile.Exists(FileName) then raise Exception.CreateFmt('Файл не найден: %s',[FileName]);
  Result := HWEBP(TWebPAnimator.CreateFromFile(FileName, Img, Loop));
end;

procedure WebPClose(Player:HWEBP); begin if Player<>nil then TWebPAnimator(Player).Free; end;
procedure WebPPlay(Player:HWEBP);  begin if Player<>nil then TWebPAnimator(Player).Start; end;
procedure WebPPause(Player:HWEBP); begin if Player<>nil then TWebPAnimator(Player).Pause; end;
procedure WebPResume(Player:HWEBP);begin if Player<>nil then TWebPAnimator(Player).Resume; end;
procedure WebPStop(Player:HWEBP);  begin if Player<>nil then TWebPAnimator(Player).Stop; end;
procedure WebPRestart(Player:HWEBP);begin if Player<>nil then TWebPAnimator(Player).Restart; end;

function WebPIsPlaying(Player:HWEBP):Boolean; begin Result := (Player<>nil) and TWebPAnimator(Player).IsPlaying; end;
function WebPIsPaused (Player:HWEBP):Boolean; begin Result := (Player<>nil) and TWebPAnimator(Player).IsPaused;  end;
function WebPIsStopped(Player:HWEBP):Boolean; begin Result := (Player=nil) or TWebPAnimator(Player).IsStopped;  end;

procedure WebPSetLoop(Player:HWEBP; LoopForever:Boolean);
begin if Player<>nil then TWebPAnimator(Player).SetLoop(LoopForever); end;

// ======== проверки ========

function WebPIsAnimatedFile(const FileName:string):Boolean; overload;
var Map:TFileMap; Data:TWebPData; dmux:PWebPDemuxer; FC:Cardinal;
begin
  Result:=False; NeedLoaded; if not TFile.Exists(FileName) then Exit;
  if not GDemuxReady then Exit;
  Map.Open(FileName);
  try
    if Map.Size>High(NativeUInt) then Exit;
    Data.bytes := PByte(Map.View); Data.size := NativeUInt(Map.Size);
    dmux := _WebPDemuxInternal(@Data,0,nil,WEBP_DEMUX_ABI_VERSION);
    if dmux<>nil then try FC := _WebPDemuxGetI(dmux, WEBP_FF_FRAME_COUNT); Result := FC>1; finally _WebPDemuxDelete(dmux); end;
  finally
    Map.Close;
  end;
end;

function WebPIsAnimatedFile(const webpms:TMemoryStream):Boolean; overload;
var Data:TWebPData; dmux:PWebPDemuxer; FC:Cardinal;
begin
  Result:=False; NeedLoaded; if (webpms=nil) or (webpms.Size=0) then Exit; if not GDemuxReady then Exit;
  Data.bytes := PByte(webpms.Memory); Data.size := webpms.Size;
  dmux := _WebPDemuxInternal(@Data,0,nil,WEBP_DEMUX_ABI_VERSION);
  if dmux<>nil then try FC := _WebPDemuxGetI(dmux, WEBP_FF_FRAME_COUNT); Result := FC>1; finally _WebPDemuxDelete(dmux); end;
end;

// ======== совместимые обёртки ========

var GAnimator:TWebPAnimator = nil;

procedure FreeGlobalAnimator; begin FreeAndNil(GAnimator); end;

procedure LoadWebPAnimToImage(const FileName:string; Img:TImage; Timer:TTimer; Loop:Boolean); overload;
begin
  NeedLoaded; FreeGlobalAnimator; GAnimator := TWebPAnimator.CreateFromFile(FileName, Img, Loop); GAnimator.Start;
end;

procedure LoadWebPAnimToImage(const mswebp:TMemoryStream; Img:TImage; Timer:TTimer; Loop:Boolean); overload;
var Bytes:TBytes;
begin
  NeedLoaded; if (mswebp=nil) or (mswebp.Size=0) then raise Exception.Create('LoadWebPAnimToImageMS: пустой поток');
  SetLength(Bytes, mswebp.Size); Move(mswebp.Memory^, Bytes[0], mswebp.Size);
  FreeGlobalAnimator; GAnimator := TWebPAnimator.CreateFromBytes(Bytes, Img, Loop); GAnimator.Start;
end;

procedure WebPAnimPause;   begin if Assigned(GAnimator) then GAnimator.Pause;   end;
procedure WebPAnimResume;  begin if Assigned(GAnimator) then GAnimator.Resume;  end;
procedure WebPAnimStop;    begin if Assigned(GAnimator) then GAnimator.Stop;    end;
procedure WebPAnimRestart; begin if Assigned(GAnimator) then GAnimator.Restart; end;

function WebPAnimIsPlaying:Boolean; begin Result := Assigned(GAnimator) and GAnimator.IsPlaying; end;
function WebPAnimIsPaused :Boolean; begin Result := Assigned(GAnimator) and GAnimator.IsPaused;  end;
function WebPAnimIsStopped:Boolean; begin Result := (GAnimator=nil) or GAnimator.IsStopped;      end;

initialization
  InitializeCriticalSection(GLoadCS);
finalization
  FreeGlobalAnimator;
  DeleteCriticalSection(GLoadCS);
end.

